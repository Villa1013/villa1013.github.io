<!-- section-hero -->
<section class="section-hero" id="home">
    <div class="tf-container">
        <div class="row">
            <div class="offset-xxl-5 col-xxl-7 offset-xl-4 col-xl-7 offset-lg-2 col-lg-8">
                <div
                    id="hero-visitor-local"
                    class="text-body-1 infor"
                    aria-live="polite"
                >
                    <span data-i18n="hero.loading_location">Loading location...</span>
                </div>
                <div class="main-title">
                    <div class="text-body-1 dot-before subtitle" data-i18n="hero.introduction">Introduction</div>
                    <h1 class="title split-text effect-right" data-i18n-html="hero.title">Innovation improves the <br> lives of many companies and people.</h1>
                    <div class="text-body-2 text" data-i18n-html="hero.description"><b>Senior Frontend Developer & Junior Full Stack Developer</b> with over 10 years of experience in developing scalable web and mobile applications based on technologies such as <b>React, TypeScript, React Native, JavaScript, Node.js and more.</b></div>
                </div>
                <div class="indicators">
                    <ul class="list-tags">
                      <li><a class="text-body-2 wow fadeInUp" href="#" data-i18n="hero.tag_web">Web Development</a></li>  
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.1s" href="#" data-i18n="hero.tag_mobile">Mobile Development</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.2s" href="#">Ecommerce</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.3s" href="#">Tech Leader</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.4s" href="#">UI/UX Design</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.5s" href="#">Art Direction</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.6s" href="#">Webflow Development</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.7s" href="#">Branding</a></li>
                    </ul>
                    <div class="indicators-wrap">
                        <div class="indicators-item wow fadeInUp">
                            <div class="text-body-1 dot-before indicators-title" data-i18n="hero.projects_worked">Projects Worked</div>
                            <div class="wg-counter style-1">
                                <div class="flex align-items-center justify-content-end">
                                    <div class="odometer text-display-2" data-number="100">100</div>
                                    <span class="sub-odo text-display-2">+</span>
                                </div>
                            </div>
                        </div>
                        <div class="indicators-item type-1 wow fadeInUp" data-wow-delay="0.1s">
                            <div class="text-body-1 dot-before indicators-title" data-i18n="hero.success_rate">Success Rate</div>
                            <div class="wg-counter style-1">
                                <div class="flex align-items-center justify-content-end">
                                    <div class="odometer text-display-2" data-number="98">98</div>
                                    <span class="sub-odo text-display-2">%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- /section-hero -->

<script is:inline>
  (function () {
    var el = document.getElementById("hero-visitor-local");
    if (!el) return;

    function formatTime() {
      var locale = navigator.language || "en-US";
      return new Date().toLocaleTimeString(locale, {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });
    }

    // Mejora del fallback: Extrae solo la ciudad o país del timezone (ej: "Europe/Madrid" -> "Madrid")
    function fallbackLocationLabel() {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      if (!tz) return "Your Location";
      return tz.split('/').pop().replace(/_/g, " ");
    }

    function render(locationLabel) {
      el.textContent = (locationLabel || fallbackLocationLabel()) + " · " + formatTime();
    }

    async function fetchLocationLabel() {
      // Intento 1: GeoJS (Suele ser más estable y sin CORS headers agresivos)
      try {
        const res = await fetch("https://get.geojs.io/v1/ip/geo.json");
        if (!res.ok) throw new Error();
        const g = await res.json();
        if (g && (g.city || g.country)) {
          return [g.city, g.country].filter(Boolean).join(", ");
        }
      } catch (e) {
        console.warn("GeoJS failed, trying fallback...");
      }

      // Intento 2: ip-api.com (Es muy rápido, pero solo funciona en HTTP a menos que sea Pro, 
      // pero Cloudflare suele dejar pasar peticiones simples)
      try {
        const res3 = await fetch("https://ipapi.co/json/");
        if (res3.status === 429) throw new Error("Rate limited");
        const d = await res3.json();
        if (d && !d.error && d.city) {
          return [d.city, d.country_name].filter(Boolean).join(", ");
        }
      } catch (e) {
        console.error("All location services failed.");
      }

      return fallbackLocationLabel();
    }

    let locationLabel = "";

    // Renderizado inicial con fallback para que no diga "Loading..." mucho tiempo
    render(fallbackLocationLabel());

    fetchLocationLabel().then(function (label) {
      locationLabel = label;
      render(locationLabel);
      // Actualizar el reloj cada 30 segundos
      setInterval(() => render(locationLabel), 30000);
    });
  })();
</script>

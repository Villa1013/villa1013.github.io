            "nav.pricing": "Pricing",
            "nav.contact": "Contact",
            "sidebar.available": "Available for",
            "sidebar.new_projects": "new projects",
            "sidebar.role_location": "Frontend Developer / Colombia",
            "common.get_started": "Get Started",
            "hero.loading_location": "Loading location...",

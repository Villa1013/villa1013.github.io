<!-- section-hero -->
<section class="section-hero" id="home">
    <div class="tf-container">
        <div class="row">
            <div class="offset-xxl-5 col-xxl-7 offset-xl-4 col-xl-7 offset-lg-2 col-lg-8">
                <div
                    id="hero-visitor-local"
                    class="text-body-1 infor"
                    aria-live="polite"
                >
                    Loading location…
                </div>
                <div class="main-title">
                    <div class="text-body-1 dot-before subtitle">Introduction</div>
                    <h1 class="title split-text effect-right">Innovation improves the <br> lives of many companies and people.</h1>
                    <div class="text-body-2 text"><b>Senior Frontend Developer & Junior Full Stack Developer</b> with over 10 years of experience in developing scalable web and mobile applications based on technologies such as <b>React, TypeScript, React Native, JavaScript, Node.js and more.</b></div>
                </div>
                <div class="indicators">
                    <ul class="list-tags">
                      <li><a class="text-body-2 wow fadeInUp" href="#">Web Development</a></li>  
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.1s" href="#">Mobile Development</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.2s" href="#">Ecommerce</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.3s" href="#">Tech Leader</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.4s" href="#">UI/UX Design</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.5s" href="#">Art Direction</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.6s" href="#">Webflow Development</a></li>
                      <li><a class="text-body-2 wow fadeInUp" data-wow-delay="0.7s" href="#">Branding</a></li>
                    </ul>
                    <div class="indicators-wrap">
                        <div class="indicators-item wow fadeInUp">
                            <div class="text-body-1 dot-before indicators-title">Projects Worked</div>
                            <div class="wg-counter style-1">
                                <div class="flex align-items-center justify-content-end">
                                    <div class="odometer text-display-2" data-number="100">100</div>
                                    <span class="sub-odo text-display-2">+</span>
                                </div>
                            </div>
                        </div>
                        <div class="indicators-item type-1 wow fadeInUp" data-wow-delay="0.1s">
                            <div class="text-body-1 dot-before indicators-title">Success Rate</div>
                            <div class="wg-counter style-1">
                                <div class="flex align-items-center justify-content-end">
                                    <div class="odometer text-display-2" data-number="98">98</div>
                                    <span class="sub-odo text-display-2">%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- /section-hero -->

<script is:inline>
  (function () {
    var el = document.getElementById("hero-visitor-local");
    if (!el) return;

    function formatTime() {
      var locale = navigator.language || "en-US";
      return new Date().toLocaleTimeString(locale, {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
      });
    }

    function fallbackLocationLabel() {
      return Intl.DateTimeFormat().resolvedOptions().timeZone.replace(/_/g, " ");
    }

    function render(locationLabel) {
      el.textContent = locationLabel + " · " + formatTime();
    }

    async function fetchLocationLabel() {
      try {
        var res = await fetch("https://ipapi.co/json/");
        var d = await res.json();
        if (!d || d.error || !d.city) throw new Error("ipapi");
        var parts = [d.city, d.region, d.country_name].filter(Boolean);
        return parts.join(", ");
      } catch (e1) {
        try {
          var res2 = await fetch("https://get.geojs.io/v1/ip/geo.json");
          var g = await res2.json();
          if (g && g.city) {
            return [g.region, g.country].filter(Boolean).join(", ");
          }
        } catch (e2) {}
      }
      return fallbackLocationLabel();
    }

    var locationLabel = "";

    function tick() {
      render(locationLabel || fallbackLocationLabel());
    }

    fetchLocationLabel().then(function (label) {
      locationLabel = label;
      tick();
      setInterval(tick, 30000);
    });
  })();
</script>
